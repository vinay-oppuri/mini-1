flowchart LR
    A[Input Logs JSON or Mock Logs]
    B[main.py\nLoad logs + fallback]
    C[Coordinator.run]
    D[LogAgent.collect\nNormalize logs + metrics]
    E[AnalysisAgent.analyze]
    E1[DrainParser\nTemplate + Event IDs]
    E2[InferencePipeline\nModel anomaly score]
    E3[Heuristic score\nPattern-based]
    F[LLMExplanationAgent.explain\nRule guess + Gemini/fallback]
    G[PolicyAgent.decide\nSeverity + allowed actions]
    H[ResponseAgent.respond\nHuman-readable actions]
    I[Final context JSON/report]

    A --> B --> C --> D --> E --> F --> G --> H --> I
    E --> E1
    E --> E2
    E --> E3

